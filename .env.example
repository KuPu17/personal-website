# ─── Database ────────────────────────────────────────
DATABASE_URL=postgresql://user:password@your-rds-host.rds.amazonaws.com:5432/kp_website?sslmode=require

# ─── Auth (required in production) ───────────────────
# Generate: npm run hash-passcode -- "your-secret-passcode"
# Local .env: use backslash-escaped $ from script output (Next.js expands bare $)
# Amplify console: paste the unescaped hash line from script output
OWNER_PASSCODE_HASH=\$2b\$12\$...your.bcrypt.hash.here...
JWT_SECRET=your-256-bit-random-secret-here
JWT_EXPIRY=7d
# Dev only — never set true in production unless you mean it
# AUTH_BYPASS=true

# ─── AWS (required for image uploads) ────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET_NAME=your-kp-media-bucket
# Public read URL for uploaded media (CloudFront or bucket URL)
AWS_CLOUDFRONT_URL=https://d1234abcd.cloudfront.net

# ─── App ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/kunchit-pujari-1712-/
NEXT_PUBLIC_EMAIL=kunchit.pujari@undext.com
